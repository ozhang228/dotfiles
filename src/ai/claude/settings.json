{
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(cd)",
      "Bash(cd *)",
      "Bash(pwd)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(find *)",
      "Bash(fd *)",
      "Bash(tree *)",
      "Bash(wc *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(which *)",
      "Bash(type *)",
      "Bash(readlink *)",
      "Bash(realpath *)",
      "Bash(basename *)",
      "Bash(dirname *)",
      "Bash(diff *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(git status *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git log)",
      "Bash(git diff *)",
      "Bash(git diff)",
      "Bash(git show *)",
      "Bash(git show)",
      "Bash(git branch *)",
      "Bash(git branch)",
      "Bash(git blame *)",
      "Bash(git rev-parse *)",
      "Bash(git ls-files *)",
      "Bash(git ls-files)",
      "Bash(git -C * diff *)",
      "Bash(git -C * status *)",
      "Bash(git -C * log *)",
      "Bash(git -C * show *)",
      "Bash(git -C * blame *)",
      "Bash(git -C * branch *)",
      "Bash(git -C * rev-parse *)",
      "Bash(git -C * ls-files *)",
      "Bash(gh pr *)",
      "Bash(gh pr)",
      "Bash(make)",
      "Bash(make *)",
      "Bash(pytest)",
      "Bash(pytest *)",
      "Bash(sed *)"
    ],
    "defaultMode": "acceptEdits",
    "additionalDirectories": [
      "/home/ozhang/drw",
      "/home/ozhang/dotfiles",
      "/home/ozhang/.claude",
      "/home/ozhang/forge"
    ]
  },
  "model": "sonnet[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/ozhang/dotfiles/src/ai/hooks/claude_code_pretooluse.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -rn --arg cwd \"$(pwd)\" --arg b \"$(git branch --show-current 2>/dev/null || echo 'not-a-repo')\" '{\"hookSpecificOutput\":{\"hookEventName\":\"UserPromptSubmit\",\"additionalContext\":(\"CWD: \"+$cwd+\"\\nBranch: \"+$b)}}'",
            "suppressOutput": true
          },
          {
            "type": "command",
            "command": "/home/ozhang/dotfiles/src/ai/hooks/claude_code_userprompt.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/ozhang/dotfiles/src/ai/hooks/claude_code_posttooluse.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "notify-send 'Claude Code' 'Done' 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); cwd=$(echo \"$input\" | jq -r '.workspace.current_dir'); model=$(echo \"$input\" | jq -r '.model.display_name'); used=$(echo \"$input\" | jq -r '.context_window.used_percentage // empty'); in_tok=$(echo \"$input\" | jq -r '.context_window.total_input_tokens // 0'); out_tok=$(echo \"$input\" | jq -r '.context_window.total_output_tokens // 0'); branch=$(git -C \"$cwd\" --no-optional-locks rev-parse --abbrev-ref HEAD 2>/dev/null || echo ''); cost=$(echo \"scale=2; ($in_tok * 15 + $out_tok * 75) / 1000000\" | bc 2>/dev/null || echo '0'); dir=$(basename \"$cwd\"); printf \"%s\" \"$dir\"; [ -n \"$branch\" ] && printf \" (%s)\" \"$branch\"; printf \" | %s\" \"$model\"; [ -n \"$used\" ] && printf \" | ctx: %.0f%%\" \"$used\"; [ \"$cost\" != \"0\" ] && [ \"$cost\" != \"0.00\" ] && printf \" | \\$%s\" \"$cost\"; echo"
  }
}
