      "Bash(git ls-files *)",
      "Bash(git -C * status)",
      "Bash(git -C * status *)",
      "Bash(git -C * log *)",
      "Bash(git -C * diff *)",
      "Bash(git -C * show *)",
      "Bash(git -C * blame *)",
      "Bash(git -C * branch *)",
      "Bash(git -C * rev-parse *)",
      "Bash(git -C * ls-files *)",
      "Bash(gh *)",
      "Bash(make)",
      "Bash(make *)",
      "Bash(pytest)",
      "Bash(pytest *)",
      "Bash(sed *)"
    ],
    "defaultMode": "acceptEdits",
    "additionalDirectories": [
      "/home/ozhang/drw",
      "/home/ozhang/dotfiles",
      "/home/ozhang/.claude",
      "/home/ozhang/forge"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/ozhang/dotfiles/src/ai/hooks/claude_code_pretooluse.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -rn --arg cwd \"$(pwd)\" --arg b \"$(git branch --show-current 2>/dev/null || echo 'not-a-repo')\" '{\"hookSpecificOutput\":{\"hookEventName\":\"UserPromptSubmit\",\"additionalContext\":(\"CWD: \"+$cwd+\"\\nBranch: \"+$b)}}'"
          },
          {
            "type": "command",
            "command": "/home/ozhang/dotfiles/src/ai/hooks/claude_code_userprompt.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/ozhang/dotfiles/src/ai/hooks/claude_code_posttooluse.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/ozhang/dotfiles/src/ai/hooks/claude_code_stop.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/ozhang/dotfiles/src/ai/hooks/skill-observation.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/home/ozhang/dotfiles/src/ai/claude/statusline.sh"
  },
  "theme": "auto",
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true
  }
}
