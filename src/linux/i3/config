# Mod1 is alt, Mod4 is windows key
set $mod              Mod1
set $smod             Shift
set $font             pango:JetBrains Mono 14
set $gap_width        3
set $gap_heigth       3
set $border_size      5
set $key_left         h
set $key_down         j
set $key_up           k
set $key_right        l

set $terminal         kitty
set $browser          google-chrome
set $app_launcher     rofi -show drun
set $compositor       picom

# Core
font $font
focus_follows_mouse yes
popup_during_fullscreen smart
default_border pixel $border_size
default_floating_border pixel $border_size

workspace 1 output DP-4
workspace 2 output DP-6
workspace 3 output DP-6

# Autostart
exec_always --no-startup-id $app_compositor
# use autorandr monitor setup, then get a random wallpaper and launch my bar
exec_always --no-startup-id "autorandr --change && bash $HOME/dotfiles/src/linux/i3/wallpaper.sh && bash $HOME/dotfiles/src/linux/polybar/launch.sh"

# hack: PipeWire on Ubuntu resets mic volume on login
exec --no-startup-id pactl set-source-volume @DEFAULT_SOURCE@ 26%

exec --no-startup-id $browser
exec --no-startup-id $terminal
exec --no-startup-id slack

bindsym $mod+Return exec $terminal
bindsym $mod+$smod+Return exec $browser
bindsym Mod4+space exec $app_launcher

bindsym XF86AudioMute exec "amixer -D pulse set Master 1+ toggle"
bindsym XF86AudioLowerVolume exec "amixer -D pulse set Master 5%-"
bindsym XF86AudioRaiseVolume exec "amixer -D pulse set Master 5%+"

# screenshot 
bindsym --release Mod4+S exec flameshot gui

### Workspaces ###
bindsym $mod+1 workspace 1
bindsym $mod+2 workspace 2
bindsym $mod+3 workspace 3
bindsym $mod+4 workspace 4
bindsym $mod+5 workspace 5
bindsym $mod+6 workspace 6
bindsym $mod+7 workspace 7
bindsym $mod+8 workspace 8
bindsym $mod+9 workspace 9
bindsym $mod+0 workspace 10

# Move focused container to workspace n
bindsym $mod+$smod+1 move container to workspace 1, workspace 1
bindsym $mod+$smod+2 move container to workspace 2, workspace 2
bindsym $mod+$smod+3 move container to workspace 3, workspace 3
bindsym $mod+$smod+4 move container to workspace 4, workspace 4
bindsym $mod+$smod+5 move container to workspace 5, workspace 5
bindsym $mod+$smod+6 move container to workspace 6, workspace 6
bindsym $mod+$smod+7 move container to workspace 7, workspace 7
bindsym $mod+$smod+8 move container to workspace 8, workspace 8
bindsym $mod+$smod+9 move container to workspace 9, workspace 9
bindsym $mod+$smod+0 move container to workspace 10, workspace 10

### Window sizes and positions ###
bindsym $mod+$key_left        focus left
bindsym $mod+$key_down        focus down
bindsym $mod+$key_up          focus up
bindsym $mod+$key_right       focus right

# Move focused window
bindsym $mod+$smod+$key_left  move left
bindsym $mod+$smod+$key_down  move down
bindsym $mod+$smod+$key_up    move up
bindsym $mod+$smod+$key_right move right

bindsym $mod+$smod+f fullscreen toggle

bindsym $mod+$smod+e exec "i3-msg exit"
bindsym $mod+$smod+r restart 
bindsym $mod+$smod+q kill

# -- Theme (Rose Pine Moon)--
set $base           #232136
set $surface        #2a273f
set $overlay        #393552
set $muted          #6e6a86
set $subtle         #908caa
set $text           #e0def4
set $love           #eb6f92
set $gold           #f6c177
set $rose           #ea9a97
set $pine           #3e8fb0
set $foam           #9ccfd8
set $iris           #c4a7e7
set $highlightlow   #2a283e
set $highlightmed   #44415a
set $highlighthigh  #56526e

# target                title          bg             text     indicator border
client.focused          $love          $love          $text    $love     $love
client.focused_inactive $surface       $surface       $subtle  $surface  $surface
client.unfocused        $surface       $surface       $subtle  $surface  $surface
client.urgent           $love          $love          $text    $love     $love
client.placeholder      $base          $base          $text    $base     $base
client.background       $base
