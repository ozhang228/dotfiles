[global]
    follow = mouse
    origin = top-right
    offset = 5x5

    width = 400

    progress_bar_min_width = 380
    progress_bar_max_width = 380
    progress_bar_corner_radius = 2

    padding = 10
    horizontal_padding = 10
    frame_width = 1
    gap_size = 3
    font = "JetBrainsMono Nerd Font 14"

    icon_position = off
    corner_radius = 2

    background = "#393552"
    foreground = "#e0def4"

    markup = full
    word_wrap = yes

    mouse_left_click = close_current
    mouse_right_click = do_action, close_current

[urgency_low]
    background = "#393955"
    highlight = "#3e8fb0"
    frame_color = "#3e8fb0"
    default_icon = "dialog-information"
    format = "<b><span foreground='#3e8fb0'>[%a] %s</span></b>\n<span size='13312'>%b</span>"
    timeout = 4

[urgency_normal]
    background = "#443c53"
    highlight = "#f6c177"
    frame_color = "#f6c177"
    default_icon = "dialog-warning"
    format = "<b><span foreground='#f6c177'>[%a] %s</span></b>\n<span size='13312'>%b</span>"
    timeout = 6

[urgency_critical]
    background = "#433754"
    highlight = "#eb6f92"
    frame_color = "#eb6f92"
    default_icon = "dialog-error"
    format = "<b><span foreground='#eb6f92'>[%a] %s</span></b>\n<span size='13312'>%b</span>"
    timeout = 0

[claude_code]
    summary = "Claude Code"
    script = ~/.config/dunst/play_sound.sh
